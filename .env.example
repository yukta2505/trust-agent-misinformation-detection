
# ── OFFLINE MODE ─────────────────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434/v1

# ── CLIP local agent (no API) ─────────────────────────────────
USE_CLIP=true
CLIP_MODEL=openai/clip-vit-base-patch32

# ── Captioning: use BLIP locally instead of GPT-4o ───────────
# Comment out or leave blank — pipeline falls back to BLIP
# OPENAI_API_KEY=         ← leave blank or comment out

# ── Disable all external APIs ────────────────────────────────
# SERPAPI_API_KEY=        ← leave blank
# NEWSAPI_KEY=            ← leave blank
# IMGBB_API_KEY=          ← leave blank

# ── Keep these ───────────────────────────────────────────────
BLIP_MODEL=Salesforce/blip-image-captioning-large
SPACY_MODEL=en_core_web_sm
USE_CLIP=true
PRISTINE_THRESHOLD=0.60
WEIGHT_ENTITY=0.25
WEIGHT_TEMPORAL=0.30
WEIGHT_CREDIBILITY=0.20
WEIGHT_CLIP=0.25

# Comma-separated list, e.g. https://your-frontend.netlify.app,https://yourdomain.com
# CORS_ALLOW_ORIGINS=
