<!-- Add aria labels to drip form inputs -->
<script>
(function () {
  function addLabels(root) {
    root.querySelectorAll('.drip-content input.drip-text-field, .dfwid-form input.drip-text-field').forEach(function (el) {
      var form = el.closest('form');
      if (form && form.getAttribute('data-drip-label-exclude') === 'true') return;

      if (!el.id) el.id = 'input-' + Math.random().toString(36).slice(2, 9);
      var text = el.getAttribute('placeholder') || el.getAttribute('title') || 'Field';
      if (!document.querySelector('label[for="'+el.id+'"]')) {
        var label = document.createElement('label');
        label.className = 'sr-only';
        label.setAttribute('for', el.id);
        label.textContent = text;
        el.parentNode && el.parentNode.insertBefore(label, el);
      }
      if (!el.hasAttribute('aria-label')) el.setAttribute('aria-label', text);
      if (el.dataset.required === 'true' || el.hasAttribute('required')) el.setAttribute('aria-required','true');
    });
  }

  function run() { addLabels(document); }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', run, { once: true });
  } else {
    run();
  }

  new MutationObserver(function (muts) {
    muts.forEach(function (m) {
      m.addedNodes.forEach(function (n) {
        if (n.nodeType === 1 && (n.matches('.drip-content, .dfwid-form') || n.querySelector?.('.drip-content, .dfwid-form'))) {
          addLabels(n);
        }
      });
    });
  }).observe(document.documentElement, { childList: true, subtree: true });
})();
</script>
<!-- End add aria labels to drip form inputs -->

